@model List<DateTime>

<!DOCTYPE html>
<html lang="pt-br">

<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css" rel="stylesheet">
    <title>Agendar Horário</title>
    <style>
            body {
                background-color: #f5f5f5;
            }

            .container {
                max-width: 700px;
                margin-top: 40px;
            }

            .horario-card {
                background: white;
                border-left: 5px solid purple;
                border-radius: 8px;
                padding: 15px 20px;
                margin-bottom: 12px;
                box-shadow: 0 2px 5px rgba(0, 0, 0, 0.1);
                display: flex;
                justify-content: space-between;
                align-items: center;
            }

            .horario-texto {
                font-size: 1.3rem;
                font-weight: bold;
            }
    </style>
</head>

<body>
    <div class="container">

        <h1 class="mb-4">Horários Disponíveis</h1>

        <form method="get" class="mb-4 d-flex gap-2 align-items-end">
            <input type="hidden" name="barbeiroId" value="@ViewBag.BarbeiroId" />
            <input type="hidden" name="servicoId" value="@ViewBag.ServicoId" />
            <div>
                <label class="form-label">Escolha o dia</label>
                <input type="date" class="form-control" name="dia" value="@ViewBag.DiaSelecionado"
                       min="@DateTime.Today.ToString("yyyy-MM-dd")" />
            </div>
            <button type="submit" class="btn btn-primary">Buscar</button>
        </form>

        @if (!Model.Any())
        {
            <p class="text-muted">Nenhum horário disponível para este dia.</p>
        }
        else
        {
            @foreach (var horario in Model)
            {
                <div class="horario-card">
                    <span class="horario-texto">@horario.ToString("HH:mm")</span>

                    <form method="post" action="/Cliente/Agendar">
                        <input type="hidden" name="barbeiroId" value="@ViewBag.BarbeiroId" />
                        <input type="hidden" name="servicoId" value="@ViewBag.ServicoId" />
                        <input type="hidden" name="horario" value="@horario.ToString("yyyy-MM-ddTHH:mm:ss")" />
                        <button type="submit" class="btn btn-success">Agendar</button>
                    </form>
                </div>
            }
        }

    </div>
</body>

</html>