@model Atendimento

<!DOCTYPE html>
<html lang="pt-br">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Editar Atendimento</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css" rel="stylesheet">
  <style>
    body { background-color: #f5f5f5; }
    .div-form { min-height: 100vh; display: flex; justify-content: center; align-items: center; }
    form {
      width: 100%;
      max-width: 450px;
      background-color: white;
      padding: 2rem;
      border-radius: 1rem;
      box-shadow: 0 2px 10px rgba(0,0,0,.1);
    }
  </style>
</head>
<body>
<div class="div-form">
  <form method="post" action="/Atendimento/Editar/@Model.Id">
    <h3 class="mb-4">Editar Horário</h3>

    <p class="text-muted">Atendimento #@Model.Id</p>

    <div class="mb-3">
      <label class="form-label">Nova data e hora</label>
      <input
        type="datetime-local"
        class="form-control"
        name="novaDataHora"
        value="@Model.DataHora.ToString("yyyy-MM-ddTHH:mm")"
        required />
    </div>

    <div class="d-flex gap-2">
      <button type="submit" class="btn btn-success w-100">Salvar</button>
      <a href="/Atendimento/Atendimentos" class="btn btn-secondary w-100">Cancelar</a>
    </div>
  </form>
</div>
</body>
</html>