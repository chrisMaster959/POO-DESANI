@model List<Servico>

<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Selecionar Serviços</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css" rel="stylesheet">

    <style>
        body {
            background-color: #f5f7fa;
            min-height: 100vh;
        }

        .container-servicos {
            max-width: 700px;
            margin: 50px auto;
            background-color: white;
            padding: 2rem;
            border-radius: 1rem;
            box-shadow: 0 2px 10px rgba(0,0,0,.1);
        }

        .titulo {
            text-align: center;
            margin-bottom: 2rem;
        }

        .card-servico {
            border: 1px solid #ddd;
            border-radius: .8rem;
            padding: 1rem;
            margin-bottom: 1rem;
            transition: .2s;
        }

        .card-servico:hover {
            background-color: #f8f9fa;
        }

        .servico-info {
            display: flex;
            justify-content: space-between;
            align-items: center;
        }

        .nome-servico {
            font-size: 1.1rem;
            font-weight: bold;
        }

        .preco-servico {
            color: #198754;
            font-weight: bold;
        }

        .btns {
            margin-top: 2rem;
            display: flex;
            justify-content: space-between;
        }
    </style>
</head>
<body>

<div class="container-servicos">

    <div class="titulo">
        <h2>Selecionar Serviços</h2>
        <p class="text-muted">
            Escolha os serviços que você realiza na barbearia
        </p>
    </div>

    <form action="/servico/salvarservicosbarbeiro" method="post">

        @foreach(var servico in Model)
        {
            <div class="card-servico">

                <div class="servico-info">

                    <div>
                        <div class="nome-servico">
                            @servico.Nome
                        </div>

                        <div class="text-muted">
                            Código: @servico.Codigo
                        </div>
                    </div>

                    <div class="text-end">

                        <div class="preco-servico">
                            R$ @servico.Preco.ToString("F2")
                        </div>

                        <div class="form-check mt-2">
                            <input
                                class="form-check-input"
                                type="checkbox"
                                name="servicosIds"
                                value="@servico.Id"
                                id="servico_@servico.Id">

                            <label
                                class="form-check-label"
                                for="servico_@servico.Id">
                                Selecionar
                            </label>
                        </div>

                    </div>

                </div>

            </div>
        }

        <div class="btns">

            <a href="/barbeiro/controle" class="btn btn-secondary">
                Voltar
            </a>

            <button type="submit" class="btn btn-success">
                Salvar Serviços
            </button>

        </div>

    </form>

</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/js/bootstrap.bundle.min.js"></script>

</body>
</html>