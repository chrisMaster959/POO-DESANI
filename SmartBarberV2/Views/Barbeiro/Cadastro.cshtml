<!DOCTYPE html>
<html lang="pt-br">
<head>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css" rel="stylesheet">

  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">

  <title>Cadastro Barbeiro</title>

  <style>
    body{
      background-color: aliceblue;
    }

    .div-form{
      min-height:100vh;
      display:flex;
      justify-content:center;
      align-items:center;
    }

    form{
      width:100%;
      max-width:450px;
      background-color:white;
      padding:2rem;
      border-radius:1rem;
      box-shadow:0 2px 10px rgba(0,0,0,.1);
    }
  </style>
</head>

<body>

<div class="div-form">

  <form action="/Barbeiro/Cadastro" method="post">

    <h3 class="mb-4">
      Completar Cadastro de Barbeiro
    </h3>

    <div class="mb-3">
      <label class="form-label">Logradouro</label>

      <input
        type="text"
        class="form-control"
        name="Logradouro"
        required>
    </div>

    <div class="mb-3">
      <label class="form-label">Número</label>

      <input
        type="number"
        class="form-control"
        name="Nr_Logradouro"
        required>
    </div>

    <div class="mb-3">
      <label class="form-label">Bairro</label>

      <input
        type="text"
        class="form-control"
        name="Bairro"
        required>
    </div>

    <div class="mb-3">
        <label class="form-label">CEP</label>

        <input
            class="form-control"
            list="listaCeps"
            name="CepNumero"
            placeholder="Digite o CEP"
            required>

        <datalist id="listaCeps">

            @foreach (var cep in ViewBag.Ceps)
            {
                <option value="@cep.Numero"></option>
            }

        </datalist>
    </div>

    <button type="submit" class="btn btn-success w-100">
      Tornar-se Barbeiro
    </button>

  </form>

</div>

</body>
</html>