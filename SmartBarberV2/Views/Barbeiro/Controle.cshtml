@model Barbeiro

@{
    var horarios = ViewBag.Horarios as List<DateTime>;
}

<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0"/>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css" rel="stylesheet">

    <title>Agenda do Barbeiro</title>
    

    <style>
        body {
            background-color: #f5f5f5;
        }

        .container {
            max-width: 1100px;
            margin-top: 40px;
        }

        .agenda-card {
            background: white;
            border-radius: 10px;
            padding: 20px;
            margin-bottom: 15px;
            box-shadow: 0 2px 5px rgba(0,0,0,0.1);
        }

        .livre {
            border-left: 5px solid green;
        }

        .ocupado {
            border-left: 5px solid red;
        }

        .horario {
            font-size: 1.4rem;
            font-weight: bold;
        }
    </style>
</head>
<body>

<div class="container">

    <h1 class="mb-4">
        Agenda de Hoje - @Model.Nome
    </h1>
    <a href="/Servico/Escolha" class="btn btn-primary mb-4">
        Gerenciar Serviços
    </a>

    @foreach (var horario in horarios)
    {
        var atendimento = Model.Atendimentos
            .FirstOrDefault(a => a.DataHora == horario);

        if (atendimento == null)
        {
            <div class="agenda-card livre">

                <div class="horario">
                    @horario.ToString("HH:mm")
                </div>

                <p class="text-success">
                    Horário disponível
                </p>

            </div>
        }
        else
        {
            <div class="agenda-card ocupado">

                <div class="horario">
                    @horario.ToString("HH:mm")
                </div>

                <p>
                    <strong>Cliente:</strong>
                    @atendimento.Cliente?.Nome
                </p>

                <p>
                    <strong>Telefone:</strong>
                    @(atendimento.Cliente?.Nome ?? "Sem cliente")
                </p>

                <p>
                    <strong>Status:</strong>
                    @atendimento.Status
                </p>

                <p>
                    <strong>Serviços:</strong>
                </p>

                <ul>
                    @foreach (var servico in atendimento.Servicos)
                    {
                        <li>
                            @servico.Nome
                        </li>
                    }
                </ul>

            </div>
        }
    }

</div>

</body>
</html>