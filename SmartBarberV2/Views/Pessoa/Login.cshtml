<!DOCTYPE html>
<html lang="pt-br">
<head>

    <meta charset="UTF-8">

    <meta
        name="viewport"
        content="width=device-width, initial-scale=1.0">

    <title>Login</title>

    <link
        href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css"
        rel="stylesheet">

    <style>

        *{
            margin:0;
            padding:0;
            box-sizing:border-box;
        }

        body{
            background-color:aliceblue;
        }

        .div-form{
            min-height:100vh;

            display:flex;
            justify-content:center;
            align-items:center;
        }

        form{
            width:100%;
            max-width:420px;

            background-color:antiquewhite;

            padding:2rem;

            border-radius:1.5rem;

            display:flex;
            flex-direction:column;
        }

        .btns{
            display:flex;
            flex-direction:column;
            gap:.8rem;
        }

        .links{
            display:flex;
            justify-content:space-between;

            margin-top:1rem;
        }

        .links a{
            text-decoration:none;
            font-weight:bold;
        }

    </style>

</head>

<body>

<div class="div-form">

    <form action="/Pessoa/Login" method="post">

        <h2 class="mb-4 text-center">
            Login
        </h2>

        @if (ViewBag.Erro != null)
        {
            <div class="alert alert-danger">
                @ViewBag.Erro
            </div>
        }

        <div class="mb-3">

            <label
                for="inputEmail"
                class="form-label">

                Email

            </label>

            <input
                type="email"
                class="form-control"
                id="inputEmail"
                name="Email"
                required>

        </div>

        <div class="mb-4">

            <label
                for="inputPassword"
                class="form-label">

                Senha

            </label>

            <input
                type="password"
                class="form-control"
                id="inputPassword"
                name="Senha"
                required>

        </div>

        <div class="btns">

            <button
                type="submit"
                class="btn btn-primary">

                Fazer login

            </button>

            <a
                href="/Pessoa/LoginBarbeiro"
                class="btn btn-dark">

                Já sou barbeiro

            </a>

        </div>

        <div class="links">

            <a href="/Pessoa/Cadastro">
                Criar conta
            </a>

        </div>

    </form>

</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/js/bootstrap.bundle.min.js"></script>

</body>
</html>